ompiled_code": "WITH deduped AS (\n\n    SELECT\n        *,\n        ROW_NUMBER() OVER (\n            PARTITION BY client_id\n            ORDER BY load_ts DESC\n        ) AS rn\n    FROM PROD_DB.bronze.stg_client\n\n)\n\nSELECT\n    client_id,\n    client_name,\n    client_type,\n    region,\n    risk_profile,\n    status,\n    source_system,\n    load_ts,\n\n    MD5(\n        COALESCE(client_name, '') ||\n        COALESCE(client_type, '') ||\n        COALESCE(region, '') ||\n        COALESCE(risk_profile, '') ||\n        COALESCE(status, '')\n    ) AS row_hash\n\nFROM deduped\nWHERE rn = 1", "relation_name": "PROD_DB.silver.silver_client", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:04:33.633542Z", "completed_at": "2026-06-23T07:04:33.637905Z"}, {"name": "execute", "started_at": "2026-06-23T07:04:33.638514Z", "completed_at": "2026-06-23T07:04:34.340577Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.7081947326660156, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53c88-000d-cd99-0000-d319000658e2"}, "message": "SUCCESS 1", "failures": null, "unique_id": "snapshot.dim_client_dbt.dim_client_snapshot", "compiled": true, "compiled_code": "\n\n\n\nselect * from PROD_DB.silver.silver_client\n", "relation_name": "PROD_DB.gold.dim_client_snapshot", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:04:34.345583Z", "completed_at": "2026-06-23T07:04:34.351189Z"}, {"name": "execute", "started_at": "2026-06-23T07:04:34.351674Z", "completed_at": "2026-06-23T07:04:34.866431Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.5220439434051514, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53c88-000d-cd99-0000-d319000658fa"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.dim_client_dbt.dim_client", "compiled": true, "compiled