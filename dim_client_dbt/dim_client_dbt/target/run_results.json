{"metadata": {"dbt_schema_version": "https://schemas.getdbt.com/dbt/run-results/v6.json", "dbt_version": "1.9.4", "generated_at": "2026-06-23T07:29:29.225232Z", "invocation_id": "25978478-1f31-4e3e-ba4a-a0bd60eb17e5", "env": {}}, "results": [{"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:26.475189Z", "completed_at": "2026-06-23T07:29:26.485156Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:26.485664Z", "completed_at": "2026-06-23T07:29:26.847005Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.3730599880218506, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065ca6"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.dim_client_dbt.stg_client", "compiled": true, "compiled_code": "-- Bronze layer: light clean/cast, 1:1 with source, no business logic\nwith source as (\n    select * from SNOWFLAKE_RND.RAW.SRC_CLIENT\n)\n\nselect\n    trim(client_id)             as client_id,\n    trim(client_name)           as client_name,\n    upper(trim(client_type))    as client_type,\n    trim(region)                as region,\n    initcap(trim(risk_profile)) as risk_profile,\n    initcap(trim(status))       as status,\n    source_system,\n    load_ts\nfrom source\nwhere client_id is not null", "relation_name": "SNOWFLAKE_RND.bronze.stg_client", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:26.853412Z", "completed_at": "2026-06-23T07:29:26.857854Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:26.858395Z", "completed_at": "2026-06-23T07:29:27.471065Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.6188302040100098, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065cbe"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.dim_client_dbt.silver_client", "compiled": true, "compiled_code": "WITH deduped AS (\n\n    SELECT\n        *,\n        ROW_NUMBER() OVER (\n            PARTITION BY client_id\n            ORDER BY load_ts DESC\n        ) AS rn\n    FROM SNOWFLAKE_RND.bronze.stg_client\n\n)\n\nSELECT\n    client_id,\n    client_name,\n    client_type,\n    region,\n    risk_profile,\n    status,\n    source_system,\n    load_ts,\n\n    MD5(\n        COALESCE(client_name, '') ||\n        COALESCE(client_type, '') ||\n        COALESCE(region, '') ||\n        COALESCE(risk_profile, '') ||\n        COALESCE(status, '')\n    ) AS row_hash\n\nFROM deduped\nWHERE rn = 1", "relation_name": "SNOWFLAKE_RND.silver.silver_client", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:27.475588Z", "completed_at": "2026-06-23T07:29:27.480097Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:27.480644Z", "completed_at": "2026-06-23T07:29:28.218324Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.7438473701477051, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065cde"}, "message": "SUCCESS 1", "failures": null, "unique_id": "snapshot.dim_client_dbt.dim_client_snapshot", "compiled": true, "compiled_code": "\n\n\n\nselect * from SNOWFLAKE_RND.silver.silver_client\n", "relation_name": "SNOWFLAKE_RND.gold.dim_client_snapshot", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:28.223244Z", "completed_at": "2026-06-23T07:29:28.227513Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:28.228114Z", "completed_at": "2026-06-23T07:29:28.815235Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.5931656360626221, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065cf6"}, "message": "SUCCESS 1", "failures": null, "unique_id": "model.dim_client_dbt.dim_client", "compiled": true, "compiled_code": "-- Gold layer: final DIM_CLIENT with surrogate key + current-row flag\nselect\n    MD5(\n        COALESCE(client_id, '') ||\n        COALESCE(dbt_valid_from, '')\n    ) as client_sk,\n    client_id,\n    client_name,\n    client_type,\n    region,\n    risk_profile,\n    status,\n    source_system,\n    dbt_valid_from                                       as effective_start_date,\n    coalesce(dbt_valid_to, '9999-12-31'::timestamp_ntz)   as effective_end_date,\n    case when dbt_valid_to is null then 'Y' else 'N' end  as is_current_flag\nfrom SNOWFLAKE_RND.gold.dim_client_snapshot", "relation_name": "SNOWFLAKE_RND.gold.dim_client", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:28.849332Z", "completed_at": "2026-06-23T07:29:28.864910Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:28.886684Z", "completed_at": "2026-06-23T07:29:29.205598Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.382476806640625, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065d4e"}, "message": null, "failures": 0, "unique_id": "test.dim_client_dbt.not_null_dim_client_client_sk.f1e564de3f", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect client_sk\nfrom SNOWFLAKE_RND.gold.dim_client\nwhere client_sk is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-06-23T07:29:28.826422Z", "completed_at": "2026-06-23T07:29:28.863412Z"}, {"name": "execute", "started_at": "2026-06-23T07:29:28.865500Z", "completed_at": "2026-06-23T07:29:29.208631Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.38661670684814453, "adapter_response": {"_message": "SUCCESS 1", "code": "SUCCESS", "rows_affected": 1, "query_id": "01c53ca1-000d-cd99-0000-d31900065d52"}, "message": null, "failures": 0, "unique_id": "test.dim_client_dbt