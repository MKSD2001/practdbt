create or replace transient table SNOWFLAKE_RND.gold.dim_client
         as
        (-- Gold layer: final DIM_CLIENT with surrogate key + current-row flag
select
    MD5(
        COALESCE(client_id, '') ||
        COALESCE(dbt_valid_from, '')
    ) as client_sk,
    client_id,
    client_name,
    client_type,
