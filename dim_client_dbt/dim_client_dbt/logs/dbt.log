        COALESCE(client_name, '') ||
        COALESCE(client_type, '') ||
        COALESCE(region, '') ||
        COALESCE(risk_profile, '') ||
        COALESCE(status, '')
    ) AS row_hash

FROM deduped
WHERE rn = 1
        );
