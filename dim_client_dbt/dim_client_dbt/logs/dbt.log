[0m00:45:08.962056 [debug] [Thread-2 (]: On model.dim_client_dbt.silver_client: /* {"app": "dbt", "dbt_version": "1.9.4", "profile_name": "dim_client_dbt", "target_name": "dev", "node_id": "model.dim_client_dbt.silver_client"} */
create or replace transient table SNOWFLAKE_RND.silver.silver_client
         as
        (WITH deduped AS (

    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY client_id
            ORDER BY load_ts DESC
        ) AS rn
    FROM SNOWFLAKE_RND.bronze.stg_client

)

SELECT
    client_id,
    client_name,
    client_type,
    region,
    risk_profile,
    status,
    source_system,
    load_ts,

    MD5(
        COALESCE(client_name, '') ||
        COALESCE(client_type, '') ||
        COALESCE(region, '') ||
        COALESCE(risk_profile, '') ||
        COALESCE(status, '')
    ) AS row_hash

FROM deduped
WHERE rn = 1
        );
