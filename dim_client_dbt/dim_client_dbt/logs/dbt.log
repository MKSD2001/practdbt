        'Approximate size of the table as reported by Snowflake' as "stats:bytes:description",
        (bytes is not null) as "stats:bytes:include",

        'Last Modified' as "stats:last_modified:label",
        to_varchar(convert_timezone('UTC', last_altered), 'yyyy-mm-dd HH24:MI'||'UTC') as "stats:last_modified:value",
        'The timestamp for last update/change' as "stats:last_modified:description",
        (last_altered is not null and table_type='BASE TABLE') as "stats:last_modified:include"
    from SNOWFLAKE_RND.INFORMATION_SCHEMA.tables
            where (
                (
                    
    "table_schema" ilike 'gold' and upper("table_schema") = upper('gold')

                    and 
    "table_name" ilike 'dim_client' and upper("table_name") = upper('dim_client')

                )
             or 
                (
                    
    "table_schema" ilike 'RAW' and upper("table_schema") = upper('RAW')

                    and 
    "table_name" ilike 'SRC_CLIENT' and upper("table_name") = upper('SRC_CLIENT')

                )
             or 
                (
                    
    "table_schema" ilike 'gold' and upper("table_schema") = upper('gold')

                    and 
    "table_name" ilike 'dim_client_snapshot' and upper("table_name") = upper('dim_client_snapshot')

                )
             or 
                (
                    
    "table_schema" ilike 'silver' and upper("table_schema") = upper('silver')

                    and 
    "table_name" ilike 'silver_client' and upper("table_name") = upper('silver_client')

                )
             or 
                (
                    
    "table_schema" ilike 'bronze' and upper("table_schema") = upper('bronze')

                    and 
    "table_name" ilike 'stg_client' and upper("table_name") = upper('stg_client')

                )
            )
        ),
        columns as (
            select
        table_catalog as "table_database",
        table_schema as "table_schema",
        table_name as "table_name",

        column_name as "column_name",
        ordinal_position as "column_index",
        data_type as "column_type",
        comment as "column_comment"
    from SNOWFLAKE_RND.INFORMATION_SCHEMA.columns
            where (
                (
                    
    "table_schema" ilike 'gold' and upper("table_schema") = upper('gold')

                    and 
    "table_name" ilike 'dim_client' and upper("table_name") = upper('dim_client')

                )
             or 
                (
                    
    "table_schema" ilike 'RAW' and upper("table_schema") = upper('RAW')

                    and 
    "table_name" ilike 'SRC_CLIENT' and upper("table_name") = upper('SRC_CLIENT')

                )
             or 
                (
                    
    "table_schema" ilike 'gold' and upper("table_schema") = upper('gold')

                    and 
    "table_name" ilike 'dim_client_snapshot' and upper("table_name") = upper('dim_client_snapshot')

                )
             or 
                (
                    
    "table_schema" ilike 'silver' and upper("table_schema") = upper('silver')

                    and 
    "table_name" ilike 'silver_client' and upper("table_name") = upper('silver_client')

                )
             or 
                (
                    
    "table_schema" ilike 'bronze' and upper("table_schema") = upper('bronze')

                    and 
    "table_name" ilike 'stg_client' and upper("table_name") = upper('stg_client')

                )
            )
        )
        select *
    from tables
    join columns using ("table_database", "table_schema", "table_name")
    order by "column_index"
