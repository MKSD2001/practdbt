    coalesce(dbt_valid_to, '9999-12-31'::timestamp_ntz)   as effective_end_date,
    case when dbt_valid_to is null then 'Y' else 'N' end  as is_current_flag
from SNOWFLAKE_RND.gold.dim_client_snapshot
        );
